#include "voice_assistant.h"

#include <string.h>

#include "esp_log.h"

#include "mic.h"
#include "speech.h"
#include "conversation.h"
#include "tts.h"
#include "speaker.h"

#include "ui.h"

static const char *TAG = "VOICE_ASSISTANT";

/*-------------------------------------------------------------
 * Buffers
 *------------------------------------------------------------*/

static char user_text[2048];

static char ai_reply[4096];

/*-------------------------------------------------------------
 * Initialize
 *------------------------------------------------------------*/

esp_err_t voice_assistant_init(void)
{
    ESP_LOGI(TAG, "====================================");
    ESP_LOGI(TAG, "Initializing Voice Assistant");
    ESP_LOGI(TAG, "====================================");

    memset(user_text, 0, sizeof(user_text));
    memset(ai_reply, 0, sizeof(ai_reply));

    return ESP_OK;
}

/*-------------------------------------------------------------
 * Process Complete Conversation
 *------------------------------------------------------------*/

esp_err_t voice_assistant_process(void)
{
    esp_err_t err;

    memset(user_text, 0, sizeof(user_text));
    memset(ai_reply, 0, sizeof(ai_reply));

    ESP_LOGI(TAG, "====================================");
    ESP_LOGI(TAG, "Conversation Started");
    ESP_LOGI(TAG, "====================================");

    /*
     * LCD
     */

    ui_set_status("Listening...");
    ui_set_speech_text("");

    /*
     * Record Audio
     */

    err = mic_start();

    if (err != ESP_OK)
    {
        ui_set_status("Microphone Error");

        ESP_LOGE(TAG, "Recording Failed");

        return err;
    }

    /*
     * Check Voice
     */

    if (!mic_voice_detected())
    {
        ui_set_status("Ready");

        ui_set_speech_text("No voice detected");

        ESP_LOGW(TAG, "No voice detected");

        return ESP_OK;
    }

    /*
     * Speech To Text
     */

    ui_set_status("Recognizing...");

    err = speech_recognize(user_text, sizeof(user_text));

    if (err != ESP_OK)
    {
        ui_set_status("Recognition Failed");

        ui_set_speech_text("Unable to recognize speech");

        ESP_LOGE(TAG, "Speech Recognition Failed");

        return err;
    }

    ESP_LOGI(TAG, "User : %s", user_text);

    /*
     * AI Conversation
     */

    ui_set_status("Thinking...");

    err = conversation_chat(
            user_text,
            ai_reply,
            sizeof(ai_reply));

    if (err != ESP_OK)
    {
        ui_set_status("AI Error");

        ui_set_speech_text("AI Server Error");

        ESP_LOGE(TAG, "Conversation Failed");

        return err;
    }

    ESP_LOGI(TAG, "Assistant : %s", ai_reply);

    /*
     * Update LCD
     */

    ui_set_speech_text(ai_reply);

    /*
     * Text To Speech
     */

    ui_set_status("Speaking...");

    err = tts_generate(ai_reply);

    if (err != ESP_OK)
    {
        ui_set_status("TTS Error");

        ESP_LOGE(TAG, "TTS Failed");

        return err;
    }

    /*
     * Speaker
     */

    err = speaker_play("/spiffs/tts.wav");

    if (err != ESP_OK)
    {
        ui_set_status("Speaker Error");

        ESP_LOGE(TAG, "Speaker Playback Failed");

        return err;
    }

    ui_set_status("Ready");

    ESP_LOGI(TAG, "====================================");
    ESP_LOGI(TAG, "Conversation Finished");
    ESP_LOGI(TAG, "====================================");

    return ESP_OK;
}
