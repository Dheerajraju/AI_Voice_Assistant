/*
 * ============================================================
 * ESP32-P4 AI Voice Assistant
 * LLM Client
 * ============================================================
 */

#include "llm_client.h"
#include "config.h"

#include <stdio.h>
#include <string.h>

#include "esp_http_client.h"
#include "esp_log.h"
#include "cJSON.h"

static const char *TAG = "LLM";

#define LLM_RESPONSE_BUFFER_SIZE    8192

static char response_buffer[LLM_RESPONSE_BUFFER_SIZE];

/*-------------------------------------------------------------
 * HTTP Event Handler
 *------------------------------------------------------------*/

static esp_err_t http_event_handler(esp_http_client_event_t *evt)
{
    static int response_length = 0;

    switch (evt->event_id)
    {
        case HTTP_EVENT_ON_CONNECTED:

            response_length = 0;
            memset(response_buffer, 0, sizeof(response_buffer));
            break;

        case HTTP_EVENT_ON_DATA:

            if (!esp_http_client_is_chunked_response(evt->client))
            {
                if ((response_length + evt->data_len) <
                    LLM_RESPONSE_BUFFER_SIZE)
                {
                    memcpy(response_buffer + response_length,
                           evt->data,
                           evt->data_len);

                    response_length += evt->data_len;

                    response_buffer[response_length] = '\0';
                }
            }
            break;

        default:
            break;
    }

    return ESP_OK;
}

/*-------------------------------------------------------------
 * Ask AI
 *------------------------------------------------------------*/

esp_err_t llm_generate_response(const char *prompt,
                                char *reply,
                                size_t reply_size)
{
    if (prompt == NULL ||
        reply == NULL ||
        reply_size == 0)
    {
        return ESP_ERR_INVALID_ARG;
    }

    ESP_LOGI(TAG, "=================================");
    ESP_LOGI(TAG, "Sending Prompt to AI...");
    ESP_LOGI(TAG, "Prompt:");
    ESP_LOGI(TAG, "%s", prompt);
    ESP_LOGI(TAG, "=================================");

    cJSON *root = cJSON_CreateObject();

    cJSON_AddStringToObject(root,
                            "message",
                            prompt);

    char *json_string =
        cJSON_PrintUnformatted(root);

    cJSON_Delete(root);

    if (json_string == NULL)
    {
        return ESP_FAIL;
    }

    esp_http_client_config_t config =
    {
        .url = AI_CHAT_URL,
        .method = HTTP_METHOD_POST,
        .timeout_ms = 60000,
        .event_handler = http_event_handler,
    };

    esp_http_client_handle_t client =
        esp_http_client_init(&config);

    if (client == NULL)
    {
        free(json_string);
        return ESP_FAIL;
    }

    esp_http_client_set_header(client,
                               "Content-Type",
                               "application/json");

    esp_http_client_set_post_field(client,
                                   json_string,
                                   strlen(json_string));

    esp_err_t err =
        esp_http_client_perform(client);

    free(json_string);

    if (err != ESP_OK)
    {
        ESP_LOGE(TAG,
                 "HTTP Request Failed");

        esp_http_client_cleanup(client);

        return err;
    }

    int status =
        esp_http_client_get_status_code(client);

    ESP_LOGI(TAG,
             "HTTP Status : %d",
             status);

    esp_http_client_cleanup(client);

    if (status != 200)
    {
        ESP_LOGE(TAG,
                 "AI Server returned error");

        return ESP_FAIL;
    }

    ESP_LOGI(TAG,
             "Server Response:");

    ESP_LOGI(TAG,
             "%s",
             response_buffer);

    cJSON *json =
        cJSON_Parse(response_buffer);

    if (json == NULL)
    {
        ESP_LOGE(TAG,
                 "JSON Parse Failed");

        return ESP_FAIL;
    }

    cJSON *answer =
        cJSON_GetObjectItem(json,
                            "response");

    if (answer == NULL ||
        !cJSON_IsString(answer))
    {
        cJSON_Delete(json);

        ESP_LOGE(TAG,
                 "No response field");

        return ESP_FAIL;
    }

    strncpy(reply,
            answer->valuestring,
            reply_size - 1);

    reply[reply_size - 1] = '\0';

    cJSON_Delete(json);

    ESP_LOGI(TAG,
             "AI Reply:");

    ESP_LOGI(TAG,
             "%s",
             reply);

    return ESP_OK;
}
