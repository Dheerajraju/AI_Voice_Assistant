/*
 * ============================================================
 * ESP32-P4 AI Voice Assistant
 * Audio Player
 *
 * Plays PCM audio returned by the AI server.
 *
 * Compatible:
 * ESP-IDF v5.5.4
 * Waveshare BSP v2.0.0
 * ============================================================
 */

#include "audio_player.h"

#include <string.h>

#include "esp_log.h"

#include "esp_codec_dev.h"
#include "esp_codec_dev_types.h"

#include "bsp/esp-bsp.h"

static const char *TAG = "AUDIO";

/*-------------------------------------------------------------
 * Private Variables
 *------------------------------------------------------------*/

static esp_codec_dev_handle_t speaker = NULL;

static bool initialized = false;

/*-------------------------------------------------------------
 * Initialize Speaker
 *------------------------------------------------------------*/

esp_err_t audio_player_init(void)
{
    if (initialized)
    {
        return ESP_OK;
    }

    ESP_LOGI(TAG, "====================================");
    ESP_LOGI(TAG, "Initializing Audio Player");
    ESP_LOGI(TAG, "====================================");

    esp_err_t ret;

    ret = bsp_audio_init(NULL);

    if (ret != ESP_OK)
    {
        ESP_LOGE(TAG, "bsp_audio_init failed");

        return ret;
    }

    speaker = bsp_audio_codec_speaker_init();

    if (speaker == NULL)
    {
        ESP_LOGE(TAG, "Speaker initialization failed");

        return ESP_FAIL;
    }

    esp_codec_dev_sample_info_t fs =
    {
        .sample_rate = 16000,
        .bits_per_sample = 16,
        .channel = 1,
        .channel_mask = 1,
        .mclk_multiple = 256
    };

    ret = esp_codec_dev_open(
            speaker,
            &fs);

    if (ret != ESP_CODEC_DEV_OK)
    {
        ESP_LOGE(TAG, "Codec open failed");

        return ESP_FAIL;
    }

    esp_codec_dev_set_out_vol(
            speaker,
            80);

    initialized = true;

    ESP_LOGI(TAG, "Speaker Ready");

    return ESP_OK;
}

/*-------------------------------------------------------------
 * Play PCM Buffer
 *------------------------------------------------------------*/

esp_err_t audio_player_play(
        const int16_t *pcm,
        size_t samples)
{
    if (!initialized)
    {
        ESP_LOGE(TAG, "Audio player not initialized");

        return ESP_FAIL;
    }

    if (pcm == NULL)
    {
        return ESP_ERR_INVALID_ARG;
    }

    ESP_LOGI(TAG,
             "Playing %u samples",
             (unsigned)samples);

    esp_err_t ret =
        esp_codec_dev_write(
            speaker,
            (void *)pcm,
            samples * sizeof(int16_t));

    if (ret != ESP_CODEC_DEV_OK)
    {
        ESP_LOGE(TAG,
                 "Playback failed");

        return ESP_FAIL;
    }

    ESP_LOGI(TAG,
             "Playback Finished");

    return ESP_OK;
}

/*-------------------------------------------------------------
 * Stop Playback
 *------------------------------------------------------------*/

esp_err_t audio_player_stop(void)
{
    if (!initialized)
    {
        return ESP_OK;
    }

    esp_codec_dev_close(speaker);

    initialized = false;

    ESP_LOGI(TAG,
             "Speaker Closed");

    return ESP_OK;
}
